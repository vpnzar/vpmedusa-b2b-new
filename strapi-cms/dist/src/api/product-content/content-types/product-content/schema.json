{
    "kind": "collectionType",
    "collectionName": "product_contents",
    "info": {
        "singularName": "product-content",
        "pluralName": "product-contents",
        "displayName": "Product Content"
    },
    "options": {
        "draftAndPublish": true
    },
    "pluginOptions": {},
    "attributes": {
        "SKU": {
            "type": "string",
            "maxLength": 10,
            "required": true,
            "unique": true
        },
        "Description": {
            "type": "blocks"
        },
        "Images": {
            "type": "media",
            "multiple": true,
            "allowedTypes": [
                "images",
                "files",
                "videos",
                "audios"
            ]
        }
    }
}
